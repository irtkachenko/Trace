# рџЊђ App Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PORT=3000

# вљЎ Supabase (РћС‚СЂРёРјР°С‚Рё РІ Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Server-only: use for admin access to storage config (do NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here


# рџ—„пёЏ Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# Google OAuth (Register at console.cloud.google.com)
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret
